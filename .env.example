# ============================================================
# Environment Configuration Template
# Copy to .env and fill in your API keys:  cp .env.example .env
# ============================================================

# ── LLM Configuration ───────────────────────────────────────
# At minimum, configure ONE provider with its API key and model.

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_PROD_MODEL=gpt-4o
# OPENAI_DEV_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google (Gemini)
# GOOGLE_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# DeepSeek
# DEEPSEEK_API_KEY=your-key-here

# Mistral
# MISTRAL_API_KEY=your-key-here

# Perplexity
# PERPLEXITY_API_KEY=pplx-your-key-here

# ── Default Model ───────────────────────────────────────────
# Fallback model used when no specific model is configured.
# DEFAULT_LLM_MODEL=gpt-4o

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379/0

# ── Authentication ──────────────────────────────────────────
# JWT_SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# ── Vector Database ───────────────────────────────────────
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=legalcopilot_cases

# ── Storage ───────────────────────────────────────────────
# S3_BUCKET=legalcopilot-documents
# S3_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Embedding Model ──────────────────────────────────────
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── RAG Pipeline ─────────────────────────────────────────
# RAG_TOKEN_BUDGET=6000
# RAG_TOP_K=10

# ── API Server ───────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
# CORS_ORIGINS=http://localhost:3000
# RATE_LIMIT_RPM=100

# ── Application ─────────────────────────────────────────────
# APP_ENV=development
# DEBUG=true
# LOG_LEVEL=INFO
